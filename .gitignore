# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Excessive documentation (keep repo clean)
START_HERE.md
REORGANIZATION_SUMMARY.md
GETTING_STARTED.md
docs/
reorganize.bat
cleanup-backups.bat
.github-cleanup.bat

# Temp files
temp_*
*.backup
env.template

# Keep only essential docs
!README.md
!SETUP.md

